# Supercharge Queue environment template
# Copy to .env.local for local development and fill values from the operator's
# secret manager. Never commit .env.local or real keys.

# Browser-visible configuration (safe to expose through NEXT_PUBLIC_*).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_ONESIGNAL_APP_ID=
NEXT_PUBLIC_APP_URL=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
NEXT_PUBLIC_TERMS_VERSION=2026-07-22

# Server-only secrets. Do not rename these with a NEXT_PUBLIC_ prefix.
SUPABASE_DATABASE_URL=
ONESIGNAL_REST_API_KEY=
CRON_SECRET=
TURNSTILE_SECRET_KEY=
QUEUE_IDEMPOTENCY_SECRET=
QUEUE_TERMS_VERSION=2026-07-22

# Optional local database validation only (localhost is enforced by the
# validation script; this is not used by the deployed application).
DATABASE_URL=
